#!/usr/bin/env bash
set -euo pipefail

install -d -m 0700 /var/lib/burn_dragon_p2p

for attempt in $(seq 1 120); do
  if aws ssm get-parameter \
    --region "${aws_region}" \
    --with-decryption \
    --name "${head_mirror_auth_bundle_parameter_name}" \
    --query 'Parameter.Value' \
    --output text >/var/lib/burn_dragon_p2p/bootstrap-head-mirror-auth-bundle.json; then
    chmod 0600 /var/lib/burn_dragon_p2p/bootstrap-head-mirror-auth-bundle.json
    exit 0
  fi
  sleep 10
done

echo "bootstrap head mirror auth bundle did not appear in SSM parameter store: ${head_mirror_auth_bundle_parameter_name}" >&2
exit 1
