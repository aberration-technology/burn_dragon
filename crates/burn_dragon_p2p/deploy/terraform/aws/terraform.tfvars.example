stack_name              = "burn-dragon-p2p-mainnet"
environment_name        = "production"
aws_region              = "us-east-2"
route53_zone_name       = "aberration.technology"
edge_domain_name        = "edge.dragon.aberration.technology"
browser_app_base_url     = "https://dragon.aberration.technology"
auth_redirect_base_url  = "https://dragon.aberration.technology"
browser_app_pages_domain_target = "aberration-technology.github.io"
bootstrap_install_source = "crate"
bootstrap_crate_version  = "0.21.0-pre.79"
# bootstrap_git_ref      = "main"
secret_parameter_prefix = "/burn-dragon-p2p/mainnet/bootstrap"

network_id              = "burn-dragon-mainnet"
project_family_id       = "burn-dragon-language"
study_id                = "burn-dragon-mainnet"
release_train_hash      = "burn-dragon-mainnet-train"

auth_connector_kind     = "github"
auth_authority_name     = "burn-dragon-auth"
# github_required_org   = "mosure"
# github_required_team  = "mosure/trainers"
github_required_repo    = "mosure/burn_dragon"
github_admin_logins     = ["mosure"]
github_admin_required_repo_permission = "admin"

instance_type           = "t3a.small"
root_volume_size_gib    = 32
data_volume_size_gib    = 64
use_retained_bootstrap_data_volume = false
enable_data_volume_snapshots = false
data_volume_snapshot_retention_days = 14
enable_disaster_recovery_snapshot_copies = false
disaster_recovery_snapshot_retention_days = 14
enable_managed_control_plane_redis = false
enable_bootstrap_status_alarms = true
enable_control_plane_operational_alarms = true
enable_control_plane_dashboard = true
create_artifact_bucket = true
create_artifact_replica_bucket = true
# dataset_domain_name = "datasets.dragon.aberration.technology"
# dataset_bucket_name = "dragon-aberration-technology-datasets-prod"
# dataset_bucket_path_prefix = "dragon-datasets"
# dataset_bucket_force_destroy = false
managed_trainer_desired_capacity = 0
managed_trainer_backend = "cpu"
managed_trainer_experiment_kind = "nca"

# Optional:
# disaster_recovery_region = "us-west-2"
