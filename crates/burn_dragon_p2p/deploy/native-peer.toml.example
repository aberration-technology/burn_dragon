training_config_paths = ["config/local/generated/p2p/nca.toml"]
storage_root = "runs/p2p/mainnet-native-wgpu"
target = "trainer"
app_semver = "0.21.0-pre.16"
enabled_features_label = "native,wgpu"

[network]
# Fill these at deploy time or override them via CLI flags.
edge_base_url = "https://MAINNET_EDGE_URL"
seed_node_urls = []
listen_addresses = [
  "/ip4/0.0.0.0/tcp/4001",
  "/ip4/0.0.0.0/udp/4001/quic-v1",
  "/ip4/0.0.0.0/udp/443/webrtc-direct",
]
external_addresses = [
  "/ip4/PUBLIC_IP/tcp/4001",
  "/ip4/PUBLIC_IP/udp/4001/quic-v1",
  "/ip4/PUBLIC_IP/udp/443/webrtc-direct",
]

[manifest]
project_family_id = "burn-dragon-language"
network_id = "burn-dragon-net"
study_id = "burn-dragon-study"
experiment_id = "language-pretraining"
revision_id = "r1"
display_name = "burn_dragon language pretraining"
description = "burn_dragon peer-to-peer language training network"
protocol_major = 0
authority_public_keys = []
bootstrap_addrs = []

[capability_policy]
native_wgpu_memory_budget_bytes = 4294967296
allow_native_validator_fallback = false
