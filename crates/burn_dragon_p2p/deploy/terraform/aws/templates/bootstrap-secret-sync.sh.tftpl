#!/usr/bin/env bash
set -euo pipefail

AWS_REGION="${aws_region}"
ENV_FILE="/etc/burn-dragon-p2p/bootstrap.env"
BOOTSTRAP_NODE_ROLE="${bootstrap_node_role}"
AUTHORITY_KEY_PARAMETER_NAME="${authority_key_name}"
AUTHORITY_KEY_PATH="${authority_key_path}"
CONTROL_PLANE_REDIS_ENABLED="${control_plane_redis_enabled}"
CONTROL_PLANE_REDIS_AUTH_TOKEN_NAME="${control_plane_redis_auth_token_name}"
CONTROL_PLANE_REDIS_ENDPOINT="${control_plane_redis_endpoint}"
CONTROL_PLANE_REDIS_PORT="${control_plane_redis_port}"
AWS_CLI_CONNECT_TIMEOUT="$${AWS_CLI_CONNECT_TIMEOUT:-5}"
AWS_CLI_READ_TIMEOUT="$${AWS_CLI_READ_TIMEOUT:-15}"

install -d -m 0755 /etc/burn-dragon-p2p
install -d -m 0700 "$(dirname "$AUTHORITY_KEY_PATH")"

if [ -f "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  . "$ENV_FILE"
fi

ssm_get_parameter() {
  aws ssm get-parameter \
    --region "$AWS_REGION" \
    --cli-connect-timeout "$AWS_CLI_CONNECT_TIMEOUT" \
    --cli-read-timeout "$AWS_CLI_READ_TIMEOUT" \
    --with-decryption \
    --name "$1" \
    --query 'Parameter.Value' \
    --output text
}

%{ if control_plane_redis_enabled ~}
shared_redis_url="$${BURN_P2P_SHARED_REDIS_URL:-}"
if [ -z "$shared_redis_url" ]; then
  redis_auth_token="$(ssm_get_parameter "$CONTROL_PLANE_REDIS_AUTH_TOKEN_NAME")"
  shared_redis_url="rediss://:$${redis_auth_token}@$CONTROL_PLANE_REDIS_ENDPOINT:$CONTROL_PLANE_REDIS_PORT/0"
fi
%{ endif ~}

%{ if auth_client_credentials_required ~}
auth_client_id="$${BURN_P2P_AUTH_CLIENT_ID:-}"
auth_client_secret="$${BURN_P2P_AUTH_CLIENT_SECRET:-}"
if [ -z "$auth_client_id" ]; then
  auth_client_id="$(ssm_get_parameter "${auth_client_id_name}" || true)"
fi
if [ -z "$auth_client_secret" ]; then
  auth_client_secret="$(ssm_get_parameter "${auth_client_secret_name}" || true)"
fi
if [ -z "$auth_client_id" ] || [ "$auth_client_id" = "None" ]; then
  echo "missing bootstrap auth client id and no cached $ENV_FILE value is available" >&2
  exit 1
fi
if [ -z "$auth_client_secret" ] || [ "$auth_client_secret" = "None" ]; then
  echo "missing bootstrap auth client secret and no cached $ENV_FILE value is available" >&2
  exit 1
fi

python3 - "$ENV_FILE" "$${auth_client_id}" "$${auth_client_secret}" "${auth_redirect_uri}" %{ if control_plane_redis_enabled ~}"$${shared_redis_url}"%{ endif ~} <<'PYENV'
from pathlib import Path
import sys

output_path = Path(sys.argv[1])
values = {
    "BURN_P2P_AUTH_CLIENT_ID": sys.argv[2],
    "BURN_P2P_AUTH_CLIENT_SECRET": sys.argv[3],
    "BURN_P2P_AUTH_REDIRECT_URI": sys.argv[4],
}
%{ if control_plane_redis_enabled ~}
values["BURN_P2P_SHARED_REDIS_URL"] = sys.argv[5]
%{ endif ~}

with output_path.open("w", encoding="utf-8") as handle:
    for key, value in values.items():
        escaped = value.replace("\\", "\\\\").replace("\"", "\\\"")
        handle.write(f'{key}="{escaped}"\n')
PYENV
%{ else ~}
%{ if control_plane_redis_enabled ~}
python3 - "$ENV_FILE" "$${shared_redis_url}" <<'PYENV'
from pathlib import Path
import sys

output_path = Path(sys.argv[1])
value = sys.argv[2]
with output_path.open("w", encoding="utf-8") as handle:
    escaped = value.replace("\\", "\\\\").replace("\"", "\\\"")
    handle.write(f'BURN_P2P_SHARED_REDIS_URL="{escaped}"\n')
PYENV
%{ else ~}
: >"$ENV_FILE"
%{ endif ~}
%{ endif ~}

fetch_authority_key() {
  ssm_get_parameter "$AUTHORITY_KEY_PARAMETER_NAME" 2>/dev/null
}

if [ -s "$AUTHORITY_KEY_PATH" ]; then
  chmod 0600 "$AUTHORITY_KEY_PATH"
  authority_key_b64=""
else
  authority_key_b64="$(fetch_authority_key || true)"
fi
if [ -n "$authority_key_b64" ] && [ "$authority_key_b64" != "None" ]; then
  printf '%s' "$authority_key_b64" | base64 --decode >"$AUTHORITY_KEY_PATH"
  chmod 0600 "$AUTHORITY_KEY_PATH"
elif [ "$BOOTSTRAP_NODE_ROLE" != "primary" ]; then
  for attempt in $(seq 1 120); do
    authority_key_b64="$(fetch_authority_key || true)"
    if [ -n "$authority_key_b64" ] && [ "$authority_key_b64" != "None" ]; then
      printf '%s' "$authority_key_b64" | base64 --decode >"$AUTHORITY_KEY_PATH"
      chmod 0600 "$AUTHORITY_KEY_PATH"
      break
    fi
    sleep 5
  done
  if [ ! -s "$AUTHORITY_KEY_PATH" ]; then
    echo "timed out waiting for shared bootstrap authority key in SSM" >&2
    exit 1
  fi
fi

chmod 0600 "$ENV_FILE"
